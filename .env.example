# ============================================================================
# Open RLM Memory - Local Consumer Hosting Configuration
# ============================================================================
# Copy to .env and adjust values for your environment.

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ----------------------------------------------------------------------------
# PostgreSQL + pgvector
# ----------------------------------------------------------------------------
DB_TYPE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=rlm_memory
POSTGRES_SERVER=postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/rlm_memory

# Application-managed PostgreSQL cache table TTL (seconds)
SEARCH_CACHE_TTL_SECONDS=300

# Default namespace used when X-Memory-Namespace header is missing
DEFAULT_MEMORY_NAMESPACE=local
MAX_NAMESPACE_LENGTH=64

# ----------------------------------------------------------------------------
# LM Studio (OpenAI-compatible API)
# ----------------------------------------------------------------------------
# LM Studio hosted on another device in your LAN.
# Example: OPENAI_BASE_URL=http://<your-lm-studio-host>:1234/v1
OPENAI_BASE_URL=http://<your-lm-studio-host>:1234/v1
OPENAI_API_KEY=lm-studio

# Optional: dedicated OpenAI-compatible endpoint/key for embeddings.
# Leave empty to fall back to OPENAI_BASE_URL and OPENAI_API_KEY.
EMBED_OPENAI_BASE_URL=
EMBED_OPENAI_API_KEY=

# Required defaults
OPENAI_MODEL=mistralai/ministral-3-14b-reasoning
EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b@q4_k_m
EMBEDDING_DIMENSIONS=1536

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Frontend (optional override)
# ----------------------------------------------------------------------------
# Leave unset for same-origin API when served from the unified container.
# VITE_API_URL=http://localhost:8000
